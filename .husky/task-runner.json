{
  "tasks": [
    {
      "name": "Format code",
      "command": "dotnet",
      "args": [
        "format",
        "fastinventoryInventory.csproj",
        "--verify-no-changes"
      ],
      "group": "pre-commit"
    },
    {
      "name": "Build with analyzers",
      "command": "dotnet",
      "args": [
        "build",
        "fastinventoryInventory.csproj",
        "-c",
        "Release"
      ],
      "group": "pre-push"
    }
  ]
}